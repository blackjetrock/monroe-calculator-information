////////////////////////////////////////////////////////////////////////////////
//
// Emulate a cassette drive
//
//


int last_pwsw = 1;
int last_clk = 0;
int last_wd = 0;

int clk = 0;
int wd = 0;
int cmmnd = 0;
int cnt = 0;
int cnt_counter = 0;

////////////////////////////////////////////////////////////////////////////////
//
// Core 1 handles the emulation of either a ROM cartridge or a cvassette drive
//
//

#define TICK 0

uint32_t now = 0;
uint32_t last_time = 0;

void core1_main(void)
{
#if TICK
  int i = 0;
#endif
  
  
  while(1)
    {

      // Update timed values
      now = time_us_32();

      if( (now - last_time) > 250000 )
        {
          // 250ms hs elapsed, update cnt
          cnt = !cnt;
          last_time = now;
        }
      
#if TICK
      i++;
      if( (i % 1000000) == 0 )
        {
          printf("\nCore1 tick psws:%d", pwsw);
        }
#endif

      
      pwsw    = gpio_get(PIN_PWSW);
      clk     = gpio_get(PIN_CLK);
      wd      = gpio_get(PIN_WD);
      cmmnd   = gpio_get(PIN_CMMND);
      
      // Check power switch
      if( last_pwsw != pwsw )
        {
          //      printf("\n                   PWSW change: %d  %llu", pwsw, to_us_since_boot(get_absolute_time()));
          pwsw_edge_count++;
        }

      // Update the photo detector COUNT signal. When the tape is moving, it causes a repeating signal. Not sure exactly
      // what this is, but we maintain a CNT signal.
      
      if( last_clk != clk )
        {
          clk_edge_count++;

          if( clk == 1 )
            {
              // Shift another data bit into command register
              command_register >>=1;
              command_register += cmmnd;
            }
          //printf("\n                   CLK change: %d  %llu", clk, to_us_since_boot(get_absolute_time()));
        }



      if( clk == 0 )
        {
          // Set up the signals that should be present when the clock is low
          // HSW and WE
          
        }
      else
        {
          // Set up the signals that should be present when the clock is high
          // COUNT and RD
          gpio_put(PIN_CNT_HSW, cnt);
        }
      
      if( last_wd != wd )
        {
          wd_edge_count++;
        }
      
      last_pwsw = pwsw;
      last_clk = clk;
      last_wd = wd;
      
      if (pwsw)
        {
          // Power on
          gpio_put(PIN_MCMT_CNT, cnt);
        }
      else
        {
          // Power off
          
          // GPIOs need to indicate cassette is present and set up in idle states
          
          gpio_put(PIN_SI1,  0);
          gpio_put(PIN_SIO1, 0);
          
          // Make high to signal MCT is present
          //set_gpio_input(PIN_MCMT_CNT);
          gpio_put(PIN_MCMT_CNT, 1);
        }
    }
}

